Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-exception-escape,
  misc-include-cleaner,
  performance-*,
  -performance-avoid-endl,
  -performance-enum-size,
  readability-redundant-*,

HeaderFilterRegex: '.*/include/hegel/.*|.*/src/.*'

# nlohmann/json declares types in internal detail headers, so include-cleaner
# traces e.g. nlohmann::json to nlohmann/detail/... instead of nlohmann/json.hpp,
# causing false alarm "unused include" and "missing include" warnings.
CheckOptions:
  - key: misc-include-cleaner.IgnoreHeaders
    value: "nlohmann/.*"
